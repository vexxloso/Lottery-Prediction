# Copy to .env and fill in values. Do not commit .env.

# MongoDB (backend and scripts)
# No password required; auth is optional.
# Local:   MONGO_URI=mongodb://localhost:27017
# VPS (no auth): MONGO_URI=mongodb://YOUR_VPS_IP:27017  (or use hostname instead of IP)
# VPS (with auth): MONGO_URI=mongodb://USERNAME:PASSWORD@localhost:27017  (URL-encode special chars in PASSWORD)
# MONGO_DB=lottery

# Optional: El Gordo real-platform bot (loteriasyapuestas.es login)
# LOTTERY_LOGIN_USERNAME=your_email_or_nif
# LOTTERY_LOGIN_PASSWORD=your_password
# LOTTERY_BOT_HEADLESS=false   # set to false on PC to see the browser when testing
